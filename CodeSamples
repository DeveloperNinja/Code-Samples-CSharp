        private readonly List<WeakReference<IObserver<T>>> _subs = new();

        public IDisposable Subscribe(IObserver<T> observer)
        {
            _subs.Add(new WeakReference<IObserver<T>>(observer));
            return new Subscription(() => _subs.RemoveAll(r =>
                r.TryGetTarget(out var t) && ReferenceEquals(t, observer)));
        }

        public void Publish(T item)
        {
            foreach (var weak in _subs.ToList())
                if (weak.TryGetTarget(out var obs)) obs.OnNext(item);
        }

        private class Subscription : IDisposable
        {
            private Action _remove;
            public Subscription(Action remove) => _remove = remove;
            public void Dispose() => _remove();
        }
    }

