        // ─────────────────────────────────────────────────────────────────────
        // Example 11: Methods & Parameters
        // Concepts: overloading, default params, ref/out/in, params keyword
        // ─────────────────────────────────────────────────────────────────────
        static void Example11_MethodsAndParameters()
        {
            Console.WriteLine("--- Example 11: Methods & Parameters ---");

            // Basic method call
            Console.WriteLine(Greet("Alice"));           // Hello, Alice!
            Console.WriteLine(Greet("Bob", "Hi"));       // Hi, Bob!

            // Method overloading — same name, different parameters
            Console.WriteLine(Add(3, 4));                // 7
            Console.WriteLine(Add(3.0, 4.0));            // 7
            Console.WriteLine(Add(1, 2, 3, 4, 5));       // 15  (params array)

            // ref — pass value type by reference (caller's variable is modified)
            int val = 10;
            Double(ref val);
            Console.WriteLine(val);                      // 20

            // out — method MUST assign before returning
            bool ok = TryDivide(10, 2, out double quotient);
            Console.WriteLine($"{ok}, {quotient}");      // True, 5

            // in — pass by reference but read-only inside method (performance hint)
            var pt = new System.Drawing.Point(3, 4);
            // Console.WriteLine(Magnitude(in pt));      // requires System.Drawing

            // Expression-bodied method (C# 6+)
            static double Square(double x) => x * x;
            Console.WriteLine(Square(9));                // 81
        }

        static string Greet(string name, string greeting = "Hello") => $"{greeting}, {name}!";

        static int    Add(int a, int b)       => a + b;
        static double Add(double a, double b) => a + b;
        static int    Add(params int[] nums)  => nums.Sum();  // params: call with any # of args

        static void Double(ref int n) => n *= 2;

        static bool TryDivide(int a, int b, out double result)
        {
            if (b == 0) { result = 0; return false; }
            result = (double)a / b;
            return true;
        }

        // ─────────────────────────────────────────────────────────────────────
        // Example 12: List<T> and Dictionary<TKey, TValue>
        // Concepts: generic collections, CRUD, iteration
        // ─────────────────────────────────────────────────────────────────────
        static void Example12_ListAndDictionary()
        {
            Console.WriteLine("--- Example 12: List & Dictionary ---");

            // List<T>
            var fruits = new List<string> { "apple", "banana", "cherry" };
            fruits.Add("date");
            fruits.Insert(1, "avocado");          // insert at index 1
            fruits.Remove("banana");              // remove first occurrence
            Console.WriteLine(fruits.Count);      // 4
            Console.WriteLine(fruits.Contains("cherry")); // True
            fruits.Sort();
            Console.WriteLine(string.Join(", ", fruits)); // apple, avocado, cherry, date

            // List searching
            int idx = fruits.FindIndex(f => f.StartsWith("a")); // first match
            Console.WriteLine(idx);               // 0
            var aFruits = fruits.FindAll(f => f.Contains("a"));
            Console.WriteLine(string.Join(", ", aFruits));  // apple, avocado, date

            // Dictionary<TKey, TValue>
            var student = new Dictionary<string, object>
            {
                ["name"]    = "Bob",
                ["age"]     = 22,
                ["gpa"]     = 3.5
            };
            student["email"] = "bob@school.edu";    // add/update key
            student.Remove("email");

            // Safe access
            if (student.TryGetValue("gpa", out object gpa))
                Console.WriteLine($"GPA: {gpa}");   // GPA: 3.5

            // Iteration
            foreach (var (key, value) in student)
                Console.WriteLine($"  {key}: {value}");

            Console.WriteLine(student.ContainsKey("name"));  // True
        }

        // ─────────────────────────────────────────────────────────────────────
        // Example 13: Tuples & Deconstruction
        // Concepts: ValueTuple, named tuples, deconstruct, swap trick
        // ─────────────────────────────────────────────────────────────────────
        static void Example13_Tuples()
        {
            Console.WriteLine("--- Example 13: Tuples ---");

            // Named tuple — ValueTuple with element names (C# 7+)
            var point = (X: 3.0, Y: 4.0);
            Console.WriteLine(point.X);         // 3
            Console.WriteLine(point.Y);         // 4

            // Method returning named tuple
            var (min, max, avg) = MinMaxAvg(new[] { 4, 7, 2, 9, 1 });
            Console.WriteLine($"Min={min}, Max={max}, Avg={avg:F1}"); // Min=1, Max=9, Avg=4.6

            // Deconstruction — unpack into separate variables
            (int a, int b) = (10, 20);
            Console.WriteLine($"a={a}, b={b}");  // a=10, b=20

            // Swap using tuple deconstruction (no temp variable needed!)
            (a, b) = (b, a);
            Console.WriteLine($"a={a}, b={b}");  // a=20, b=10  (swapped)

            // Discard _ — ignore tuple elements you don't need
            var (_, second, _) = (1, 2, 3);
            Console.WriteLine(second);           // 2

            // Tuple equality (C# 7.3+)
            var t1 = (1, "hello");
            var t2 = (1, "hello");
            Console.WriteLine(t1 == t2);         // True
        }

        static (int Min, int Max, double Avg) MinMaxAvg(int[] data) =>
            (data.Min(), data.Max(), data.Average());

        // ─────────────────────────────────────────────────────────────────────
        // Example 14: Enums & Structs
