        // ─────────────────────────────────────────────────────────────────────
        // Example 1: Hello World & Output Formatting
        // Concepts: Console.Write/WriteLine, string interpolation, verbatim strings
        // ─────────────────────────────────────────────────────────────────────
        static void Example01_HelloWorldAndOutput()
        {
            Console.WriteLine("--- Example 1: Hello World & Output ---");

            // Basic output
            Console.WriteLine("Hello, World!");                      // Hello, World!

            // String interpolation ($"") — preferred modern style
            string name = "Alice";
            int age = 30;
            double gpa = 3.85;
            Console.WriteLine($"Hello, {name}! Age: {age}, GPA: {gpa:F2}"); 
            // Hello, Alice! Age: 30, GPA: 3.85

            // Format specifiers inside interpolation
            double price = 1234567.89;
            Console.WriteLine($"Price: {price:C}");     // Price: $1,234,567.89 (culture-dependent)
            Console.WriteLine($"Pi:    {Math.PI:F4}");  // Pi:    3.1416
            Console.WriteLine($"Hex:   {255:X}");       // Hex:   FF
            Console.WriteLine($"Pad:   {42,10}");       // Pad:          42  (right-aligned in 10 chars)
            Console.WriteLine($"Left:  {42,-10}|");     // Left:  42        |

            // Verbatim string — @ prefix, no escape processing
            string path = @"C:\Users\Alice\Documents\file.txt";
            Console.WriteLine(path);   // C:\Users\Alice\Documents\file.txt

            // Multi-line raw string literal (C# 11+)
            // string json = """
            //     { "name": "Alice" }
            //     """;

            // String.Format — older style, still common in legacy code
            Console.WriteLine(String.Format("Name: {0}, Age: {1}", name, age));
        }

        // ─────────────────────────────────────────────────────────────────────
        // Example 2: Variables & Data Types
        // Concepts: value types, reference types, var, const, sizeof
        // ─────────────────────────────────────────────────────────────────────
        static void Example02_VariablesAndDataTypes()
        {
            Console.WriteLine("--- Example 2: Variables & Data Types ---");

            // Value types — stored on the stack
            int    myInt    = 42;
            long   myLong   = 9_876_543_210L;   // digit separators for readability
            double myDouble = 3.14159265358979;
            float  myFloat  = 3.14f;             // f suffix required
            decimal myDecimal = 19.99m;          // m suffix; exact decimal math (financial)
            bool   myBool   = true;
            char   myChar   = 'A';

            // Reference types — stored on the heap
            string myStr    = "C# is great";
            object myObj    = 42;               // boxing: int → object

            // var — compiler infers type (still strongly typed)
            var inferred = "I'm a string";      // type is string at compile time
            Console.WriteLine(inferred.GetType()); // System.String

            // const — compile-time constant
            const double GravityMs2 = 9.81;

            // Checking type
            Console.WriteLine(myInt.GetType());       // System.Int32
            Console.WriteLine(myStr is string);       // True
            Console.WriteLine(myObj is int boxed);    // True  (pattern matching + declaration)
            Console.WriteLine(boxed);                 // 42

            // Default values
            int    defaultInt    = default;    // 0
            bool   defaultBool   = default;    // False
            string defaultString = default;    // null

            Console.WriteLine($"Sizes: int={sizeof(int)}, long={sizeof(long)}, " +
                              $"double={sizeof(double)}, char={sizeof(char)}");
            // Sizes: int=4, long=8, double=8, char=2
        }

        // ─────────────────────────────────────────────────────────────────────
        // Example 3: Arithmetic & Math Operations
        // Concepts: operators, Math class, checked arithmetic, integer division
        // ─────────────────────────────────────────────────────────────────────
        static void Example03_ArithmeticAndMath()
        {
            Console.WriteLine("--- Example 3: Arithmetic & Math ---");

            int a = 17, b = 5;

            Console.WriteLine(a + b);    // 22
            Console.WriteLine(a - b);    // 12
            Console.WriteLine(a * b);    // 85
            Console.WriteLine(a / b);    // 3   — integer division truncates!
            Console.WriteLine(a % b);    // 2   — modulo (remainder)
            Console.WriteLine((double)a / b);  // 3.4  — cast to double first

            // Exponentiation (no ** operator in C#; use Math.Pow)
            Console.WriteLine(Math.Pow(2, 10));   // 1024
            Console.WriteLine(Math.Sqrt(144));    // 12
            Console.WriteLine(Math.Abs(-42));     // 42
            Console.WriteLine(Math.Ceiling(3.2)); // 4
            Console.WriteLine(Math.Floor(3.9));   // 3
            Console.WriteLine(Math.Round(3.5, MidpointRounding.AwayFromZero)); // 4
            Console.WriteLine(Math.Log(100, 10)); // 2
            Console.WriteLine(Math.PI);           // 3.141592653589793

            // Augmented assignment operators
            int x = 10;
            x += 5;   // 15
            x -= 3;   // 12
            x *= 2;   // 24
            x /= 4;   // 6
            x %= 4;   // 2
            Console.WriteLine(x);  // 2

            // Increment/Decrement
            int n = 5;
            Console.WriteLine(n++);  // 5 — post-increment: returns then increments
            Console.WriteLine(n);    // 6
            Console.WriteLine(++n);  // 7 — pre-increment: increments then returns

            // Overflow detection with checked
            try
            {
                checked
                {
                    int max = int.MaxValue;
                    int overflow = max + 1;   // throws OverflowException
                }
            }
            catch (OverflowException)
            {
                Console.WriteLine("OverflowException caught in checked block");
            }
        }

        // ─────────────────────────────────────────────────────────────────────
        // Example 4: Strings & String Methods
        // Concepts: immutability, common methods, StringBuilder, interpolation
        // ─────────────────────────────────────────────────────────────────────
        static void Example04_StringsAndStringMethods()
        {
            Console.WriteLine("--- Example 4: Strings & String Methods ---");

            string s = "Hello, C# World!";

            // Properties
            Console.WriteLine(s.Length);              // 16
            Console.WriteLine(s[0]);                  // H  (indexer)
            Console.WriteLine(s[^1]);                 // !  (index from end, C# 8+)

            // Slicing with Range (C# 8+)
            Console.WriteLine(s[7..9]);               // C#
            Console.WriteLine(s[..5]);                // Hello
            Console.WriteLine(s[7..]);                // C# World!

            // Common methods
            Console.WriteLine(s.ToUpper());           // HELLO, C# WORLD!
            Console.WriteLine(s.ToLower());           // hello, c# world!
            Console.WriteLine(s.Replace("World", "Universe")); // Hello, C# Universe!
            Console.WriteLine(s.Contains("C#"));     // True
            Console.WriteLine(s.StartsWith("Hello")); // True
            Console.WriteLine(s.IndexOf("World"));   // 10
            Console.WriteLine(s.Substring(7, 2));    // C#
            Console.WriteLine("  spaces  ".Trim());  // 'spaces'

            // Split and Join
            string csv = "apple,banana,cherry";
            string[] fruits = csv.Split(',');
            Console.WriteLine(fruits[1]);             // banana
            Console.WriteLine(string.Join(" | ", fruits)); // apple | banana | cherry

            // String comparison (always use Ordinal for code, CurrentCulture for UI)
            Console.WriteLine(string.Equals("abc", "ABC", StringComparison.OrdinalIgnoreCase)); // True

            // StringBuilder — efficient mutable string (avoids creating many string objects)
            var sb = new StringBuilder();
            for (int i = 1; i <= 5; i++)
                sb.Append(i).Append(i < 5 ? ", " : "");
            Console.WriteLine(sb.ToString());         // 1, 2, 3, 4, 5

            // String.IsNullOrEmpty / IsNullOrWhiteSpace
            Console.WriteLine(string.IsNullOrEmpty(""));      // True
            Console.WriteLine(string.IsNullOrWhiteSpace(" ")); // True
        }

        // ─────────────────────────────────────────────────────────────────────
        // Example 5: Arrays
        // Concepts: single/multi-dim arrays, Array methods, ranges
        // ─────────────────────────────────────────────────────────────────────
        static void Example05_ArrayBasics()
        {
            Console.WriteLine("--- Example 5: Arrays ---");

            // Declaration and initialization
            int[] numbers = { 64, 34, 25, 12, 22, 11, 90 };
            string[] fruits = new string[3];   // allocated but uninitialized (null)
            fruits[0] = "apple";
            fruits[1] = "banana";
            fruits[2] = "cherry";

            Console.WriteLine(numbers.Length);    // 7
            Console.WriteLine(numbers[0]);        // 64
            Console.WriteLine(numbers[^1]);       // 90  (last element)

            // Sorting and searching
            Array.Sort(numbers);
            Console.WriteLine(string.Join(", ", numbers));  // 11, 12, 22, 25, 34, 64, 90
            int idx = Array.BinarySearch(numbers, 25);
            Console.WriteLine($"25 is at index {idx}");    // 25 is at index 2

            // Array.IndexOf — linear search
            int pos = Array.IndexOf(fruits, "banana");
            Console.WriteLine(pos);              // 1

            // Copy, Reverse, Clear
            int[] copy = new int[numbers.Length];
            Array.Copy(numbers, copy, numbers.Length);
            Array.Reverse(copy);
            Console.WriteLine(string.Join(", ", copy));  // 90, 64, 34, 25, 22, 12, 11

            // 2D array (rectangular)
            int[,] matrix = { { 1, 2, 3 }, { 4, 5, 6 }, { 7, 8, 9 } };
            Console.WriteLine(matrix[1, 2]);     // 6  (row 1, col 2)

            // Jagged array — array of arrays (rows can have different lengths)
            int[][] jagged = new int[3][];
            jagged[0] = new[] { 1, 2 };
            jagged[1] = new[] { 3, 4, 5 };
            jagged[2] = new[] { 6 };
            Console.WriteLine(jagged[1][2]);     // 5
        }

        // ─────────────────────────────────────────────────────────────────────
        // Example 6: Conditional Statements
        // Concepts: if/else, switch expression, ternary, pattern matching
        // ─────────────────────────────────────────────────────────────────────
        static void Example06_ConditionalStatements()
        {
            Console.WriteLine("--- Example 6: Conditionals ---");

            int score = 78;

            // Classic if/else if/else
            string grade;
            if      (score >= 90) grade = "A";
            else if (score >= 80) grade = "B";
            else if (score >= 70) grade = "C";
            else if (score >= 60) grade = "D";
            else                  grade = "F";
            Console.WriteLine($"Score {score} → Grade {grade}");  // Score 78 → Grade C

            // Ternary operator
            string status = score >= 60 ? "Pass" : "Fail";
            Console.WriteLine(status);   // Pass

            // Switch statement (classic)
            int day = 3;
            switch (day)
            {
                case 1: Console.WriteLine("Monday"); break;
                case 2: Console.WriteLine("Tuesday"); break;
                case 3: Console.WriteLine("Wednesday"); break;
                default: Console.WriteLine("Other"); break;
            }

            // Switch expression (C# 8+) — concise and returns a value
            string dayName = day switch
            {
                1 => "Monday",
                2 => "Tuesday",
                3 => "Wednesday",
                4 => "Thursday",
                5 => "Friday",
                _ => "Weekend"   // _ is the discard (default)
            };
            Console.WriteLine(dayName);   // Wednesday

            // Type pattern matching (C# 7+)
            object obj = 3.14;
            if (obj is double d)
                Console.WriteLine($"It's a double: {d}");  // It's a double: 3.14

            // Switch with pattern matching (C# 9+ relational patterns)
            string classification = score switch
            {
                >= 90 => "Excellent",
                >= 70 => "Good",
                >= 50 => "Average",
                _     => "Below Average"
            };
            Console.WriteLine(classification);   // Good
        }

        // ─────────────────────────────────────────────────────────────────────
        // Example 7: Loops
        // Concepts: for, while, do-while, foreach, break, continue, goto
        // ─────────────────────────────────────────────────────────────────────
        static void Example07_Loops()
        {
            Console.WriteLine("--- Example 7: Loops ---");

            // for loop
            for (int i = 0; i < 5; i++)
                Console.Write(i + " ");   // 0 1 2 3 4
            Console.WriteLine();

            // while loop
            int count = 5;
            while (count > 0)
            {
                Console.Write(count + " ");
                count--;
            }
            Console.WriteLine();  // 5 4 3 2 1

            // do-while — executes body at least once
            int x = 0;
            do
            {
                Console.Write(x + " ");
                x++;
            } while (x < 3);
            Console.WriteLine();  // 0 1 2

            // foreach — iterate over any IEnumerable
            string[] fruits = { "apple", "banana", "cherry" };
            foreach (string fruit in fruits)
                Console.Write(fruit + " ");
            Console.WriteLine();  // apple banana cherry

            // break and continue
            for (int i = 0; i < 10; i++)
            {
                if (i == 3) continue;   // skip 3
                if (i == 7) break;      // stop at 7
                Console.Write(i + " ");
            }
            Console.WriteLine();  // 0 1 2 4 5 6

            // Nested loops with labeled break using goto
            for (int i = 0; i < 3; i++)
            {
                for (int j = 0; j < 3; j++)
                {
                    if (i == 1 && j == 1) goto Done;
                    Console.Write($"({i},{j}) ");
                }
            }
            Done:
            Console.WriteLine("← jumped here");  // (0,0) (0,1) (0,2) (1,0) ← jumped here
        }

        // ─────────────────────────────────────────────────────────────────────
        // Example 8: Type Conversion & Parsing
        // Concepts: implicit/explicit cast, Convert, TryParse, as/is
        // ─────────────────────────────────────────────────────────────────────
        static void Example08_TypeConversionAndParsing()
        {
            Console.WriteLine("--- Example 8: Type Conversion & Parsing ---");

            // Implicit conversion (safe, no data loss)
            int myInt = 42;
            double myDouble = myInt;         // int → double is implicit
            Console.WriteLine(myDouble);     // 42

            // Explicit cast (may lose data)
            double pi = 3.14159;
            int truncated = (int)pi;         // truncates decimal part
            Console.WriteLine(truncated);    // 3

            // Convert class — handles null and uses culture settings
            string numStr = "123";
            int converted = Convert.ToInt32(numStr);
            Console.WriteLine(converted);    // 123
            Console.WriteLine(Convert.ToBoolean(1));  // True
            Console.WriteLine(Convert.ToString(255, 16)); // ff (base 16)

            // int.TryParse — safe parsing, no exception on failure
            string input = "42abc";
            if (int.TryParse(input, out int result))
                Console.WriteLine($"Parsed: {result}");
            else
                Console.WriteLine($"'{input}' is not a valid integer");
            // '42abc' is not a valid integer

            // TryParse returns true/false; out parameter holds result
            Console.WriteLine(double.TryParse("3.14", out double d));  // True
            Console.WriteLine(d);                                       // 3.14

            // as operator — returns null instead of throwing on failure
            object obj = "Hello";
            string? str = obj as string;     // succeeds: str = "Hello"
            int?  num   = obj as int?;       // fails: num = null (no exception)
            Console.WriteLine(str);          // Hello
            Console.WriteLine(num is null);  // True

            // Boxing and Unboxing
            int boxable = 99;
            object boxed = boxable;          // boxing: value type → object (heap)
            int unboxed = (int)boxed;        // unboxing: must cast to exact type
            Console.WriteLine(unboxed);      // 99
        }

        // ─────────────────────────────────────────────────────────────────────
        // Example 9: Nullable Types & Null Handling
        // Concepts: Nullable<T>, ??, ??=, ?., null-forgiving operator
        // ─────────────────────────────────────────────────────────────────────
        static void Example09_NullableTypesAndNullCoalescing()
        {
            Console.WriteLine("--- Example 9: Nullable Types & Null Handling ---");

            // Nullable value type — int? is shorthand for Nullable<int>
            int? maybeAge = null;
            Console.WriteLine(maybeAge.HasValue);       // False
            Console.WriteLine(maybeAge.GetValueOrDefault(0)); // 0

            maybeAge = 25;
            Console.WriteLine(maybeAge.HasValue);       // True
            Console.WriteLine(maybeAge.Value);          // 25

            // Null-coalescing operator ?? — return right if left is null
            string? name = null;
            string displayName = name ?? "Anonymous";
            Console.WriteLine(displayName);             // Anonymous

            // ??= null-coalescing assignment (C# 8+)
            name ??= "Default Name";                   // assigns only if null
            Console.WriteLine(name);                   // Default Name

            // Null-conditional operator ?. — short-circuits on null
            string? maybeStr = null;
            int? length = maybeStr?.Length;            // null instead of NullReferenceException
            Console.WriteLine(length is null);         // True

            string? value = "Hello";
            Console.WriteLine(value?.ToUpper());       // HELLO
            Console.WriteLine(value?.Length ?? -1);    // 5

            // Null-conditional with indexer and method chaining
            List<string>? list = null;
            int? count = list?.Count;                  // null, not exception
            Console.WriteLine(count ?? 0);             // 0

            // Null-forgiving operator ! — tells compiler "trust me, not null"
            // Use sparingly — suppresses nullable warnings only
            string definitelyNotNull = name!;          // asserts non-null at design time
        }

