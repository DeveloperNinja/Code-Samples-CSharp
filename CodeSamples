            sw.Stop();
            Console.WriteLine($"3 concurrent fetches in {sw.ElapsedMilliseconds}ms");
            foreach (var r in results) Console.WriteLine("  " + r);

            // Task.WhenAny — first one to finish wins
            var fastest = await Task.WhenAny(tasks);
            Console.WriteLine("Fastest: " + await fastest);

