    class ProductCatalog
    {
        private readonly List<DomainProduct> _products = new();
        private int _nextOrderId = 1000;

        public void AddProduct(DomainProduct p) => _products.Add(p);

        public async Task<Result<PlacedOrder>> PlaceOrderAsync(OrderRequest request)
        {
            await Task.Delay(10);  // simulate async I/O

            var lines = new List<PlacedOrderLine>();
            foreach (var item in request.Items)
            {
                var product = _products.FirstOrDefault(p => p.Id == item.ProductId);
                if (product is null)
                    return Result<PlacedOrder>.Failure($"Product {item.ProductId} not found.");
                if (item.Quantity > product.Stock)
                    return Result<PlacedOrder>.Failure(
                        $"Insufficient stock for '{product.Name}': " +
                        $"requested {item.Quantity}, available {product.Stock}.");

                product.SoldUnits += item.Quantity;
                lines.Add(new PlacedOrderLine(product.Name, item.Quantity, product.Price));
            }

            var order = new PlacedOrder($"ORD-{++_nextOrderId}", lines.ToArray());
            return Result<PlacedOrder>.Success(order);
        }

        public IEnumerable<(string Name, int Units, decimal Revenue)> GetRevenueReport() =>
            _products.Select(p => (p.Name, p.SoldUnits, p.SoldUnits * p.Price));
    }
}

