        // ─────────────────────────────────────────────────────────────────────
        // Example 48: Observer Pattern & Mediator
        // Concepts: IObservable<T>/IObserver<T>, Reactive Extensions style
        // ─────────────────────────────────────────────────────────────────────
        static void Example48_ObserverAndMediator()
        {
            Console.WriteLine("--- Example 48: Observer & Mediator ---");

            // Custom IObservable<T> implementation
            var bus = new EventBus2<OrderEvent>();

            // Subscribe multiple observers
            bus.Subscribe(new EmailNotifier());
            bus.Subscribe(new InventoryUpdater());
            IDisposable sub = bus.Subscribe(new AuditLogger());

            bus.Publish(new OrderEvent { OrderId = 101, Amount = 49.99m });
            // Email: Order #101 placed ($49.99)
            // Inventory: reducing stock for Order #101
            // Audit: Order #101 logged at ...

            // Unsubscribe
            sub.Dispose();
            bus.Publish(new OrderEvent { OrderId = 102, Amount = 9.99m });
            // AuditLogger no longer receives events

            // Simple Mediator pattern
            var mediator = new SimpleMediator();
            mediator.Register<CreateUserCommand>(cmd =>
                Console.WriteLine($"Handler: Creating user '{cmd.Name}'"));
            mediator.Register<DeleteUserCommand>(cmd =>
                Console.WriteLine($"Handler: Deleting user {cmd.UserId}"));

            mediator.Send(new CreateUserCommand { Name = "Alice" });
            mediator.Send(new DeleteUserCommand { UserId = 42 });
        }

        // ─────────────────────────────────────────────────────────────────────
        // Example 49: Pipeline Builder Pattern (Middleware)
        // Concepts: chain of responsibility, ASP.NET Core–style middleware pipeline
        // ─────────────────────────────────────────────────────────────────────
        static void Example49_PipelineBuilderPattern()
        {
            Console.WriteLine("--- Example 49: Pipeline Builder ---");

            var pipeline = new PipelineBuilder<RequestContext>()
                .Use(async (ctx, next) =>
                {
                    Console.WriteLine($"[Auth] Checking token for {ctx.Path}");
                    if (ctx.Headers.ContainsKey("Authorization"))
                    {
                        await next(ctx);
                    }
                    else
                    {
                        ctx.Response = "401 Unauthorized";
                    }
                })
                .Use(async (ctx, next) =>
                {
                    var sw = Stopwatch.StartNew();
                    await next(ctx);
                    Console.WriteLine($"[Timing] {ctx.Path} took {sw.ElapsedMilliseconds}ms");
                })
                .Use(async (ctx, next) =>
                {
                    Console.WriteLine($"[Handler] Processing {ctx.Path}");
                    ctx.Response = $"200 OK: {ctx.Path}";
                    await next(ctx);
                })
                .Build();

            var ctx1 = new RequestContext("/api/users", new() { ["Authorization"] = "Bearer token" });
            pipeline(ctx1).GetAwaiter().GetResult();
            Console.WriteLine(ctx1.Response);
            // [Auth] Checking token for /api/users
            // [Timing] /api/users took Xms
            // [Handler] Processing /api/users
            // 200 OK: /api/users

            var ctx2 = new RequestContext("/api/secret", new());
            pipeline(ctx2).GetAwaiter().GetResult();
            Console.WriteLine(ctx2.Response);  // 401 Unauthorized
        }

