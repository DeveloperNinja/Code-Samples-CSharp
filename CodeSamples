        static async Task RunAsyncDemo()
        {
            // Awaiting a single task
            string result = await FetchDataAsync("https://api.example.com/data");
            Console.WriteLine(result);  // Data from https://api.example.com/data

            // Run tasks concurrently with Task.WhenAll
            var sw = Stopwatch.StartNew();
            Task<string>[] tasks =
