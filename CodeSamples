    class SimpleContainer
    {
        readonly Dictionary<Type, Func<object>> _factories = new();
        readonly Dictionary<Type, object> _singletons = new();

        public void Register<TInterface, TImpl>() where TImpl : TInterface
        {
            _factories[typeof(TInterface)] = () => CreateWithInjection(typeof(TImpl));
        }

        public void RegisterSingleton<TInterface, TImpl>() where TImpl : TInterface
        {
            _factories[typeof(TInterface)] = () =>
            {
                if (!_singletons.ContainsKey(typeof(TInterface)))
                    _singletons[typeof(TInterface)] = CreateWithInjection(typeof(TImpl));
                return _singletons[typeof(TInterface)];
            };
        }

        public T Resolve<T>() => (T)_factories[typeof(T)]();

        private object CreateWithInjection(Type type)
        {
            var ctor = type.GetConstructors().OrderByDescending(c => c.GetParameters().Length).First();
            var args = ctor.GetParameters().Select(p => _factories[p.ParameterType]()).ToArray();
            return ctor.Invoke(args);
        }
    }

