        static async Task RunEcommerceDemo()
        {
            // Strongly-typed domain models (records)
            var catalog = new ProductCatalog();
            catalog.AddProduct(new DomainProduct(1, "Widget",   9.99m,  100));
            catalog.AddProduct(new DomainProduct(2, "Gadget",   24.99m, 50));
            catalog.AddProduct(new DomainProduct(3, "Doohickey", 4.99m, 200));

            // Result<T> pattern — explicit error handling without exceptions
            var result = await catalog.PlaceOrderAsync(new OrderRequest(
                CustomerId: "C001",
                Items: new[]
                {
                    new OrderItem(ProductId: 1, Quantity: 3),
                    new OrderItem(ProductId: 2, Quantity: 1),
                }
            ));

            result.Match(
                onSuccess: order =>
                {
                    Console.WriteLine($"Order {order.Id} placed!");
                    Console.WriteLine($"Total: {order.Total:C}");
                    Console.WriteLine($"Items: {order.Items.Length}");
                    foreach (var item in order.Items)
                        Console.WriteLine($"  {item.Name} x{item.Qty} @ {item.UnitPrice:C}");
                },
                onFailure: error =>
                {
                    Console.WriteLine($"Order failed: {error}");
                }
            );

            // LINQ reporting — top products by revenue
            Console.WriteLine("\n--- Revenue Report ---");
            var report = catalog.GetRevenueReport()
                .OrderByDescending(r => r.Revenue)
                .Take(3);
            foreach (var (name, units, revenue) in report)
                Console.WriteLine($"  {name,-12} | {units,3} units | {revenue,8:C}");

            // Failed order — insufficient stock
            var failResult = await catalog.PlaceOrderAsync(new OrderRequest(
                CustomerId: "C002",
                Items: new[] { new OrderItem(1, 9999) }   // too many
            ));
            failResult.Match(
                onSuccess: _ => Console.WriteLine("Should not succeed"),
                onFailure: error => Console.WriteLine($"Expected failure: {error}")
            );
        }
