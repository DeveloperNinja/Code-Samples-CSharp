        // ─────────────────────────────────────────────────────────────────────
        // Example 15: Exception Handling
        // Concepts: try/catch/finally, when filters, custom exceptions, throw expressions
        // ─────────────────────────────────────────────────────────────────────
        static void Example15_ExceptionHandling()
        {
            Console.WriteLine("--- Example 15: Exception Handling ---");

            // Basic try/catch/finally
            static double Divide(double a, double b)
            {
                try
                {
                    if (b == 0) throw new DivideByZeroException("Denominator cannot be zero.");
                    return a / b;
                }
                catch (DivideByZeroException ex)
                {
                    Console.WriteLine($"Caught: {ex.Message}");
                    return double.NaN;
                }
                finally
                {
                    Console.WriteLine("Divide() call finished.");  // always runs
                }
            }

            Console.WriteLine(Divide(10, 2));   // 5  → Divide() call finished.
            Console.WriteLine(Divide(10, 0));   // Caught: ... → Divide() call finished.

            // Catch with when filter — catches only when condition is true
            try
            {
                int[] arr = new int[3];
                arr[5] = 1;  // IndexOutOfRangeException
            }
            catch (IndexOutOfRangeException ex) when (ex.Message.Contains("index"))
            {
                Console.WriteLine("Caught with when filter");
            }

            // Exception hierarchy — catch most specific first
            try { throw new ArgumentNullException("name"); }
            catch (ArgumentNullException ex) { Console.WriteLine($"ArgumentNull: {ex.ParamName}"); }
            catch (ArgumentException)        { Console.WriteLine("Argument (never reached)"); }

            // Custom exception
            try { SetAge(-1); }
            catch (InvalidAgeException ex)
            { Console.WriteLine($"Custom: {ex.Message}, Age={ex.Age}"); }

            // Throw expression (C# 7+) — throw inside expressions
            static string NonNull(string? s) => s ?? throw new ArgumentNullException(nameof(s));
            Console.WriteLine(NonNull("ok"));  // ok
        }

        static void SetAge(int age)
        {
            if (age < 0 || age > 150) throw new InvalidAgeException(age);
        }

