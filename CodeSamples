        static void Example34_ExpressionTrees()
        {
            Console.WriteLine("--- Example 34: Expression Trees ---");

            // Lambda vs Expression Tree
            Func<int, int>              lambda = x => x * x;   // compiled code
            System.Linq.Expressions.Expression<Func<int, int>> expr = x => x * x;   // data (AST)

            // Inspect the tree
            Console.WriteLine(expr);                      // x => (x * x)
            Console.WriteLine(expr.Body);                 // (x * x)
            Console.WriteLine(expr.Body.NodeType);        // Multiply
            Console.WriteLine(expr.Parameters[0].Name);   // x

            // Compile to executable delegate at runtime
            Func<int, int> compiled = expr.Compile();
            Console.WriteLine(compiled(9));               // 81

            // Build expression tree programmatically (what ORM frameworks do)
            var param = System.Linq.Expressions.Expression.Parameter(typeof(int), "n");
            var body  = System.Linq.Expressions.Expression.Multiply(param, param);
            var built = System.Linq.Expressions.Expression.Lambda<Func<int, int>>(body, param);
            Console.WriteLine(built.Compile()(7));        // 49

            // Practical: simulate Entity Framework "Where" translation
            // Expression<Func<Student, bool>> filter = s => s.Age > 18;
            // SQL translator inspects the tree → "WHERE Age > 18"
            Console.WriteLine("Expression trees power EF Core, AutoMapper, and more.");
        }

