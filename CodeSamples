        // ─────────────────────────────────────────────────────────────────────
        // Example 36: Task Parallel Library (TPL)
        // Concepts: Parallel.For, Parallel.ForEach, PLINQ, Task.Run
        // ─────────────────────────────────────────────────────────────────────
        static void Example36_TaskParallelLibrary()
        {
            Console.WriteLine("--- Example 36: Task Parallel Library ---");

            // Parallel.For — CPU-bound work in parallel
            long[] results = new long[10];
            Parallel.For(0, 10, i =>
            {
                results[i] = SumOfSquares(i * 100_000, (i + 1) * 100_000);
            });
            Console.WriteLine($"Results computed: {results.Length}");

            // Parallel.ForEach
            var files = Enumerable.Range(1, 5).Select(i => $"file{i}.txt").ToList();
            Parallel.ForEach(files, file =>
            {
                // Simulate CPU-bound processing
                Thread.Sleep(10);
                Console.WriteLine($"  Processed {file} on thread {Thread.CurrentThread.ManagedThreadId}");
            });

            // PLINQ — parallel LINQ
            var sw = Stopwatch.StartNew();
            long sum = Enumerable.Range(1, 10_000_000)
                .AsParallel()           // parallel execution
                .Where(n => n % 2 == 0)
                .Sum(n => (long)n);
            Console.WriteLine($"PLINQ sum={sum}, time={sw.ElapsedMilliseconds}ms");

            // Task.Run — offload to ThreadPool
            var task = Task.Run(() => SumOfSquares(0, 1_000_000));
            Console.WriteLine($"Background result: {task.Result}");
        }

        static long SumOfSquares(int from, int to)
        {
            long sum = 0;
            for (int i = from; i < to; i++) sum += (long)i * i;
            return sum;
