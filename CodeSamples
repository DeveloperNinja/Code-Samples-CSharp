        // ─────────────────────────────────────────────────────────────────────
        static void Example46_MemoryEfficientJSON()
        {
            Console.WriteLine("--- Example 46: System.Text.Json ---");

            // Serialize to JSON string
            var person = new JsonPerson { Name = "Alice", Age = 30, Tags = new[] { "vip", "premium" } };
            var options = new JsonSerializerOptions { WriteIndented = true, PropertyNamingPolicy = JsonNamingPolicy.CamelCase };
            string json = JsonSerializer.Serialize(person, options);
            Console.WriteLine(json);

            // Deserialize
            var loaded = JsonSerializer.Deserialize<JsonPerson>(json, options);
            Console.WriteLine($"Loaded: {loaded?.Name}, tags: {loaded?.Tags?.Length}");

            // Serialize to UTF-8 bytes (zero-copy, no intermediate string)
            byte[] bytes = JsonSerializer.SerializeToUtf8Bytes(person, options);
            Console.WriteLine($"JSON size: {bytes.Length} bytes");

            // Low-level Utf8JsonWriter for maximum performance
            using var ms = new MemoryStream();
            using var writer = new System.Text.Json.Utf8JsonWriter(ms, new System.Text.Json.JsonWriterOptions { Indented = false });
            writer.WriteStartObject();
            writer.WriteString("name", "Bob");
            writer.WriteNumber("age", 25);
            writer.WriteEndObject();
            writer.Flush();
            Console.WriteLine(Encoding.UTF8.GetString(ms.ToArray())); // {"name":"Bob","age":25}

            // JsonDocument — read-only DOM for selective parsing
            using var doc = JsonDocument.Parse(json);
            string? name = doc.RootElement.GetProperty("name").GetString();
            Console.WriteLine($"DOM parse: {name}");  // Alice
        }

