        // ─────────────────────────────────────────────────────────────────────
        // Example 33: Lambdas & Closures
        // Concepts: capturing variables, static lambdas, closure pitfalls
        // ─────────────────────────────────────────────────────────────────────
        static void Example33_LambdasAndClosures()
        {
            Console.WriteLine("--- Example 33: Lambdas & Closures ---");

            // Closure — lambda captures outer variable by reference
            int multiplier = 3;
            Func<int, int> triple = n => n * multiplier;  // captures 'multiplier'
            Console.WriteLine(triple(7));   // 21
            multiplier = 5;
            Console.WriteLine(triple(7));   // 35  ← mutated! captures reference, not value

            // Fix: capture by value with local copy
            int factor = 3;
            int localFactor = factor;   // local copy
            Func<int, int> safe = n => n * localFactor;
            factor = 99;
            Console.WriteLine(safe(7));  // 21  ← unchanged

            // Classic closure loop bug
            var buggy = new List<Func<int>>();
            for (int i = 0; i < 3; i++)
                buggy.Add(() => i);  // all capture the same 'i'
            // After loop, i == 3
            Console.WriteLine(string.Join(", ", buggy.Select(f => f()))); // 3, 3, 3

            // Fixed: capture loop variable with local copy
            var fixed2 = new List<Func<int>>();
            for (int i = 0; i < 3; i++)
            {
                int j = i;          // new variable each iteration
                fixed2.Add(() => j);
            }
            Console.WriteLine(string.Join(", ", fixed2.Select(f => f()))); // 0, 1, 2

            // static lambda (C# 9) — cannot capture outer variables, avoids accidental closure
            Func<int, int> staticSq = static x => x * x;
            Console.WriteLine(staticSq(7));  // 49
        }

