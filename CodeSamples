    class PipelineBuilder<T>
    {
        private readonly List<Func<Func<T, Task>, Func<T, Task>>> _middleware = new();

        public PipelineBuilder<T> Use(Func<T, Func<T, Task>, Task> middleware)
        {
            _middleware.Add(next => ctx => middleware(ctx, next));
            return this;
        }

        public Func<T, Task> Build()
        {
